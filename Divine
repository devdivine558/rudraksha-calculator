            <div>
              <label style={{ display: "block", fontSize: 13, fontWeight: 600, color: "#1c1917", marginBottom: 5 }}>Time of Birth</label>
              <input value={tob} onChange={e => setTob(e.target.value)} type="time" disabled={noTime}
