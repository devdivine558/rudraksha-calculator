              <div style={{ display: "flex", justifyContent: "center", gap: 10, flexWrap: "wrap" }}>
                {result.type === "birth" && result.data && (
                  <>
                    <span style={{ fontSize: 12, color: "#fef3c7", background: "rgba(0,0,0,0.22)", padding: "3px 12px", borderRadius: 20 }}>
                      ☉ {result.data.sunSign}
