    if (digits.length > 0 && digits.length < 10) setPhoneErr("Phone number must be 10 digits");
    else setPhoneErr("");
  };

  const canSubmit = tab === "birth"
    ? (!!dob && (!phone || phone.length === 10))
    : (!!purposeId && !!dob && (!phone || phone.length === 10));

  const handleSubmit = async () => {
    if (!canSubmit || loading) return;
    if (phone && phone.length !== 10) { setPhoneErr("Phone number must be 10 digits"); return; }

    setLoading(true); setResult(null); setAiInsight("");
    await new Promise(r => setTimeout(r, 900));

    let res;
    if (tab === "birth") {
      res = { type: "birth", data: getRecommendationByBirth(dob), name, dob, place };
    } else {
      const purposeLabel = PURPOSES.find(p => p.id === purposeId)?.label || purposeId;
      res = { type: "purpose", data: getRecommendationByPurpose(purposeId), purposeLabel, name, dob, place };
    }
    setResult(res); setLoading(false);

    // AI insight
    setAiLoading(true);
    try {
      const recs = res.type === "birth"
        ? [res.data?.primary, res.data?.secondary, res.data?.tertiary].filter(Boolean)
        : res.data;
      const recStr = recs.map(r => `${r.name} (${r.mukhi} Mukhi)`).join(", ");
      const prompt = res.type === "birth"
        ? `Person born on ${dob}${place ? ` in ${place}` : ""}. Sun sign: ${res.data?.sunSign}, Life Path: ${res.data?.lifePath}. Recommended Rudraksha: ${recStr}. Give a personal 2–3 sentence mystical Vedic insight on how these beads align with their cosmic energy. Be poetic and spiritually grounded.`
        : `Person seeking Rudraksha for "${res.purposeLabel}", born on ${dob}${place ? ` in ${place}` : ""}. Recommended: ${recStr}. Give 2–3 sentences of personal guidance on wearing and using these beads for maximum benefit. Be mystical and rooted in Vedic tradition.`;

      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514", max_tokens: 1000,
          system: "You are a wise Vedic astrologer and Rudraksha expert. Provide mystical yet practical guidance in 2–3 sentences. Be poetic and spiritually meaningful.",
          messages: [{ role: "user", content: prompt }]
        })
      });
      const data = await response.json();
      setAiInsight(data.content?.filter(b => b.type === "text").map(b => b.text).join("") || "");
    } catch (e) { setAiInsight(""); }
    setAiLoading(false);
  };

  // Shared field style
  const inp = (extra = {}) => ({
    width: "100%", boxSizing: "border-box",
    border: "1.5px solid #d6d3d1", borderRadius: 8,
    padding: "10px 14px", fontSize: 14, color: "#1c1917",
    background: "#fff", outline: "none", fontFamily: "inherit",
    transition: "border-color 0.15s, box-shadow 0.15s",
    ...extra,
  });

  const MukhiCard = ({ rec, rank }) => {
    if (!rec) return null;
    const cfg = rankConfig[rank] || rankConfig[2];
    return (
      <div style={{ background: "#fff", border: `2px solid ${cfg.border}`, borderRadius: 12, padding: "16px 18px", display: "flex", gap: 14, alignItems: "flex-start" }}>
        <div style={{ width: 50, height: 50, borderRadius: "50%", background: cfg.bg, border: `2px solid ${cfg.border}`, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", flexShrink: 0 }}>
          <span style={{ fontSize: 14, fontWeight: 800, color: cfg.color, lineHeight: 1 }}>{rec.mukhi}</span>
          <span style={{ fontSize: 8, fontWeight: 600, color: cfg.color, letterSpacing: 0.5 }}>MUKHI</span>
        </div>
        <div style={{ flex: 1, minWidth: 0 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 5 }}>
            <span style={{ fontSize: 11, fontWeight: 700, color: cfg.color, background: cfg.bg, padding: "2px 9px", borderRadius: 20, border: `1px solid ${cfg.border}`, whiteSpace: "nowrap" }}>{cfg.label}</span>
            <span style={{ fontSize: 16, fontWeight: 700, color: "#1c1917" }}>{rec.name}</span>
          </div>
          <div style={{ display: "flex", gap: 16, marginBottom: 6, flexWrap: "wrap" }}>
            <span style={{ fontSize: 12, color: "#57534e" }}><strong style={{ color: "#292524" }}>Deity:</strong> {rec.deity}</span>
            <span style={{ fontSize: 12, color: "#57534e" }}><strong style={{ color: "#292524" }}>Planet:</strong> {rec.planet}</span>
          </div>
          <p style={{ fontSize: 13, color: "#44403c", lineHeight: 1.6, margin: 0 }}>{rec.benefits}</p>
        </div>
      </div>
    );
  };

  const resultRecs = result
    ? result.type === "birth"
      ? [result.data?.primary, result.data?.secondary, result.data?.tertiary].filter(Boolean)
      : result.data
    : [];

  return (
    <div style={{ minHeight: "100vh", background: "linear-gradient(160deg, #7c2d12 0%, #92400e 50%, #78350f 100%)", padding: "36px 16px 60px", fontFamily: "'Segoe UI', system-ui, sans-serif" }}>
      <style>{`
