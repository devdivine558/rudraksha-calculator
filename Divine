            {/* AI Insight */}
            <div style={{ background: "#fffbeb", border: "1.5px solid #fcd34d", borderTop: "none", borderRadius: "0 0 14px 14px", padding: "16px 20px" }}>
              <div style={{ fontSize: 11, fontWeight: 700, color: "#92400e", letterSpacing: 1.5, textTransform: "uppercase", marginBottom: 10 }}>
                ✦ Vedic Insight
              </div>
              {aiLoading ? (
                <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                  <div style={{ width: 16, height: 16, borderRadius: "50%", border: "2.5px solid #fde68a", borderTop: "2.5px solid #b45309", animation: "spin 0.8s linear infinite", flexShrink: 0 }} />
