        )}

        <p style={{ textAlign: "center", color: "#fed7aa", fontSize: 11, marginTop: 22, letterSpacing: 2, opacity: 0.6 }}>
          OM NAMAH SHIVAYA ✦ ANCIENT VEDIC WISDOM
        </p>
      </div>
    </div>
  );
}
