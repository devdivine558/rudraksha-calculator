                )}
                {result.type === "purpose" && (
                  <span style={{ fontSize: 12, color: "#fef3c7", background: "rgba(0,0,0,0.22)", padding: "3px 12px", borderRadius: 20 }}>
                    Purpose: {result.purposeLabel}
                  </span>
                )}
                {result.place && (
                  <span style={{ fontSize: 12, color: "#fef3c7", background: "rgba(0,0,0,0.22)", padding: "3px 12px", borderRadius: 20 }}>
                    📍 {result.place}
                  </span>
                )}
              </div>
            </div>

            {/* Mukhi cards */}
            <div style={{ background: "#f9f8f7", border: "1.5px solid #e7e5e4", borderTop: "none", padding: "18px 18px", display: "flex", flexDirection: "column", gap: 10 }}>
              {resultRecs.map((rec, i) => <MukhiCard key={rec.mukhi} rec={rec} rank={i} />)}
